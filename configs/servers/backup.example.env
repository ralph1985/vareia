BACKUP_ROOT=/opt/backups
RETENTION_DAYS=30
BACKUP_REMOTE_ROOT=backups/VareIA
BACKUP_POSTGRES_IMAGE=postgres:17

HOME_MANAGER_ENV_FILE=/opt/infra/home-manager/.env
AUTOMATION_ENV_FILE=/opt/infra/automation/.env

ONEDRIVE_SYNC_DIR=/home/monis/apps/onedrive-file-sync

# loto-sync (Vercel export API)
LOTO_SYNC_REMOTE_SYNC_BASE_URL=https://your-loto-sync.vercel.app
LOTO_SYNC_DB_SYNC_TOKEN=change_me

# Optional. If empty, script tries SLACK_WEBHOOK_URL from AUTOMATION_ENV_FILE.
SLACK_WEBHOOK_URL=
