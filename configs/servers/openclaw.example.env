# Copy this file to: configs/servers/openclaw-<server>.env
# Never commit real tokens, IDs or secrets.

# Service runtime
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:0.1.0
OPENCLAW_MEM_LIMIT=256m
OPENCLAW_CPUS=0.25
OPENCLAW_LOG_LEVEL=info
OPENCLAW_LANGUAGE=es
OPENCLAW_SOCKET_MODE=true
OPENCLAW_DM_ONLY=true
OPENCLAW_ALLOW_CHANNEL_RESPONSES=false

# Slack identity and auth
SLACK_BOT_TOKEN=__SET_XOXB_TOKEN__
SLACK_APP_TOKEN=__SET_XAPP_TOKEN__
SLACK_SIGNING_SECRET=__SET_SIGNING_SECRET__
OWNER_SLACK_USER_ID=__SET_OWNER_SLACK_USER_ID__

# Approval policy (v1)
OPENCLAW_APPROVAL_REQUIRED=true
OPENCLAW_APPROVAL_EXPIRATION=none
OPENCLAW_APPROVAL_MAX_PENDING=1

# Sensitive actions policy
OPENCLAW_SENSITIVE_ACTIONS=deploy,restart,infra_config,network_security,database_mutation,backup_data,secrets

# Initial specialist agents (v1)
OPENCLAW_AGENT_CATALOG=infra-devops,automatizaciones-n8n,producto-roadmap,frontend-ui,backend-api,qa-testing,code-review,release-ops

# Audit and persistence
OPENCLAW_AUDIT_LOG_PATH=/var/log/openclaw/audit.log
OPENCLAW_AUDIT_RETENTION_DAYS=90
OPENCLAW_DATA_DIR=/var/lib/openclaw
