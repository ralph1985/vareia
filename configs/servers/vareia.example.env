# Copy this file to: configs/servers/<server-name>.env
# Never commit real passwords.

# PostgreSQL
POSTGRES_IMAGE=postgres:17
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__SET_POSTGRES_PASSWORD__
POSTGRES_DB=postgres
POSTGRES_TZ=Europe/Madrid
POSTGRES_MEM_LIMIT=512m
POSTGRES_CPUS=0.5

# App databases
APP_N8N_DB_NAME=app_n8n
APP_N8N_DB_USER=usr_n8n
APP_N8N_DB_PASSWORD=__SET_USR_N8N_PASSWORD__

APP_OPENCLAW_DB_NAME=app_openclaw
APP_OPENCLAW_DB_USER=usr_openclaw
APP_OPENCLAW_DB_PASSWORD=__SET_USR_OPENCLAW_PASSWORD__

# n8n
N8N_IMAGE=n8nio/n8n:1.91.3
N8N_TZ=Europe/Madrid
N8N_HOST=n8n.local
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://n8n.local/
N8N_WEBHOOK_URL=http://n8n.local/
N8N_ENCRYPTION_KEY=__SET_N8N_ENCRYPTION_KEY__
N8N_EXECUTIONS_MODE=regular
N8N_EXECUTIONS_DATA_PRUNE=true
N8N_EXECUTIONS_DATA_MAX_AGE=336
N8N_MEM_LIMIT=512m
N8N_CPUS=0.5
