# Gmail bot account (no secrets in Git)
GMAIL_BOT_EMAIL=vareia.bot@gmail.com
GMAIL_APP_PASSWORD=__SET_APP_PASSWORD__

# IMAP (read)
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_IMAP_SECURE=true

# SMTP (send)
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=465
GMAIL_SMTP_SECURE=true

# Operational filters (recommended in workflow)
MAIL_ALLOWED_SENDERS=__SET_ALLOWED_SENDERS_CSV__
MAIL_SUBJECT_PREFIX=[VAREIA-CMD]
MAIL_SHARED_TOKEN=__SET_SHARED_TOKEN__
